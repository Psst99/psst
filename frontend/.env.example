NEXT_PUBLIC_SANITY_PROJECT_ID="<paste your project here>" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-28" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_STUDIO_URL="" #Optional, defaults to http://localhost:3333
SANITY_API_READ_TOKEN="<paste your token here>" # Required - The read token for your Sanity project
SANITY_API_WRITE_TOKEN="<paste your token here>" # Required for write operations (forms/submissions)
NEXT_PUBLIC_SITE_URL="https://psst.space" # Public site origin used for payment redirects
MOLLIE_API_MODE="live" # Use "live" for launch; use "test" only with a Mollie test key
MOLLIE_API_KEY="<paste your Mollie live API key>" # Required for donations checkout
MOLLIE_WEBHOOK_URL="" # Optional: public HTTPS URL for Mollie webhook (required for payment-status webhooks)
RESEND_API_KEY="<paste your Resend API key>" # Required for confirmation + donation emails
EMAIL_WEBHOOK_SECRET="<choose a shared secret>" # Optional but recommended for /api/email/approval Sanity webhook auth
GOOGLE_SHEET_ID="<paste your Google Sheet ID>" # Required for approved artist Google Sheets sync
GOOGLE_SERVICE_ACCOUNT_JSON="<paste your service account JSON>" # Required for approved artist Google Sheets sync
INFOMANIAK_NEWSLETTER_API_TOKEN="<paste your Infomaniak API token>" # Required for newsletter signups
INFOMANIAK_NEWSLETTER_DOMAIN_ID="<paste your Infomaniak newsletter domain ID>" # Required for newsletter signups
INFOMANIAK_NEWSLETTER_GROUPS="PSST website" # Optional comma-separated group IDs or names
INFOMANIAK_NEWSLETTER_FIRST_NAME_FIELD_KEY="firstname" # Optional; omit if this field is not configured in Infomaniak
INFOMANIAK_NEWSLETTER_LAST_NAME_FIELD_KEY="lastname" # Optional; omit if this field is not configured in Infomaniak
DONATION_CONFIRMATION_FROM_EMAIL="PSST <info@psst.space>" # Sender identity for donation confirmation emails
